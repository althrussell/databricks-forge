// ---------------------------------------------------------------------------
// Embeddings (pgvector)
//
// The `vector(1024)` column has no Prisma equivalent, so all reads/writes
// go through raw SQL in lib/embeddings/store.ts. This model exists so
// `prisma db push` knows about the table and does not attempt to drop it.
// ---------------------------------------------------------------------------

model ForgeEmbedding {
  id           String                      @id @default(dbgenerated("gen_random_uuid()"))
  kind         String
  sourceId     String                      @map("source_id")
  runId        String?                     @map("run_id")
  scanId       String?                     @map("scan_id")
  contentText  String                      @map("content_text")
  metadataJson Json?                       @map("metadata_json")
  embedding    Unsupported("vector(1024)")
  createdAt    DateTime                    @default(now()) @map("created_at") @db.Timestamptz()

  @@index([kind])
  @@index([sourceId])
  @@index([runId])
  @@index([scanId])
  @@map("forge_embeddings")
}

